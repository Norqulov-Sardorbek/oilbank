msgstr "Olib ketish buyurtmalari uchun filialni ko'rsatish shart"

msgid "Address is required for delivery orders"
msgstr "Yetkazib berish buyurtmalari uchun manzilni ko'rsatish shart"

msgid "Card ID is required when payment method is Card"
msgstr "To'lov usuli 'Karta' bo'lganda karta ID sini ko'rsatish shart"

msgid "Pickup time is required for pickup orders"
msgstr "Olib ketish buyurtmalari uchun olib ketish vaqtni ko'rsatish shart"

msgid "Pickup time must be at least tomorrow"
msgstr "Olib ketish vaqti eng kamida ertaga bo'lishi kerak"

msgid "Invalid or expired promo code"
msgstr "Noto'g'ri yoki muddati o'tgan promo kod"

msgid "You can only rate completed orders"
msgstr "Siz faqat yakunlangan buyurtmalarni baholay olasiz"

msgid "You can only rate your own orders"
msgstr "Siz faqat o'zingizning buyurtmalaringizni baholay olasiz"

msgid "You have already rated this order"
msgstr "Siz bu buyurtmani allaqachon baholagansiz"

msgid "Order is required"
msgstr "Buyurtma talab qilinadi"

msgid "Invalid payment method. Choose from MULTICARD, CARD, CASH, or UZUM."
msgstr "Noto'g'ri to'lov usuli. MULTICARD, CARD, CASH yoki UZUM dan tanlang."

msgid "Story marked as read"
msgstr "Hikoya o'qilgan deb belgilandi"

msgid "You are not authorized to mark this story as viewed"
msgstr "Siz bu hikoyani ko'rilgan  deb belgilash huquqiga ega emassiz"

msgid "Car number is not valid in Uzbekistan"
msgstr "Avtomobil raqami O‘zbekistonda yaroqli emas"

msgid "Order amount exceeds the maximum limit of %(max_amount)s"
msgstr "Buyurtma summasi maksimal ruxsat etilgan %(max_amount)s miqdoridan oshib ketdi"

