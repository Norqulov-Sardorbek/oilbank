msgstr "Keshbek faqat keshbek, aralash yoki onlayn to'lov usullari bilan ishlatilishi mumkin"

msgid "Secondary payment method is required for MIXED payments"
msgstr "Aralash to'lovlar uchun ikkinchi to'lov usuli talab qilinadi"

msgid "Cashback balance amount is not more than {min_amount}."
msgstr "Keshbek balansi miqdori ruxsat etilgan {min_amount} summadan kam."

msgid "Insufficient cashback balance to cover order amount"
msgstr "Buyurtma miqdorini qoplash uchun keshbek balansi yetarli emas"

msgid "Amount is less than 500 UZS after cashback deduction"
msgstr "Keshbek chegirilgandan so'ng miqdor 500 so'mdan kam"

msgid "Order amount is more than {max_amount} to use cashback."
msgstr "Keshbek ishlatish uchun buyurtma summasi {max_amount} dan oshadi."

