msgid "You have a recent SMS that you can use"
msgstr "Sizda foydalanishingiz mumkin bo'lgan yaqinda kelgan SMS mavjud"

msgid "OTP code has expired"
msgstr "OTP kodining muddati tugagan"

msgid "You already have an active OTP that you can use. Please wait %(seconds)s seconds before requesting a new one."
msgstr "Sizda foydalanishingiz mumkin bo'lgan faol OTP mavjud. Yangisini so'rashdan oldin %(seconds)s soniya kuting."

msgid "You have exceeded the SMS limit for the last 24 hours. Please wait {hours} hours before sending another SMS"
msgstr "Oxirgi 24 soat ichida SMS limitidan oshib ketdingiz. Boshqa SMS yuborishdan oldin {hours} soat kuting"

msgid "Provided phone number doesn't match your current phone number"
msgstr "Keltirilgan telefon raqami sizning hozirgi raqamingizga mos kelmaydi"

msgid "This phone number is already registered by another user"
msgstr "Ushbu telefon raqami boshqa foydalanuvchi tomonidan ro'yxatdan o'tkazilgan"

msgid "Current phone number verified successfully"
msgstr "Joriy telefon raqami muvaffaqiyatli tasdiqlandi"

msgid "Phone number changed successfully"
msgstr "Telefon raqami muvaffaqiyatli o'zgartirildi"

msgid "Invalid OTP code or phone number"
msgstr "Noto'g'ri OTP kodi yoki telefon raqami"

msgid "The phone field must be set"
msgstr "Telefon maydoni to'ldirilishi shart"

msgid "Superuser must have is_staff=True"
msgstr "Superuser is_staff=True bo'lishi kerak"

msgid "Superuser must have is_superuser=True"
msgstr "Superuser is_superuser=True bo'lishi kerak"

msgid "You cannot mark the primary address as 'non-primary'. To perform this action, please set another address as the primary one first."
msgstr "Asosiy manzilni 'asosiy emas' deb belgilay olmaysiz. Ushbu amalni bajarish uchun avval boshqa manzilni asosiy qilib belgilang."

msgid "Rating can only be given for completed bookings."
msgstr "Baholash faqat yakunlangan bronlar uchun berilishi mumkin."

msgid "You have already rated this booking."
msgstr "Siz bu bronni allaqachon baholagansiz."

msgid "Booking is required."
msgstr "Bron qilish talab qilinadi."

msgid "OTP not found for this phone number."
msgstr "Ushbu telefon raqami uchun OTP topilmadi."

msgid "OTP code has already been used."
msgstr "OTP kodi allaqachon ishlatilgan."

msgid "OTP has expired."
msgstr "OTP muddati tugagan."

msgid "Invalid OTP code."
msgstr "Noto'g'ri OTP kodi."

msgid "At least one field must be filled (image, video, or caption)."
msgstr "Kamida bitta maydon to'ldirilishi kerak (rasm, video yoki sarlavha)."

msgid "All image fields must be provided if any are filled."
msgstr "Agar biron bir maydon to'ldirilgan bo'lsa, barcha rasm maydonlari taqdim etilishi kerak."

msgid "All video fields must be provided if any are filled."
msgstr "Agar biron bir maydon to'ldirilgan bo'lsa, barcha video maydonlari taqdim etilishi kerak."

msgid "All caption fields must be provided if any are filled."
msgstr "Agar biron bir maydon to'ldirilgan bo'lsa, barcha sarlavha maydonlari taqdim etilishi kerak."

msgid "Cars retrieved successfully"
msgstr "Mashinalar muvaffaqiyatli olindi"

msgid "Car retrieved successfully"
msgstr "Mashina muvaffaqiyatli olindi"

msgid "Car created successfully"
msgstr "Mashina muvaffaqiyatli yaratildi"

msgid "Car updated successfully"
msgstr "Mashina muvaffaqiyatli yangilandi"

msgid "Car partially updated successfully"
msgstr "Mashina qisman muvaffaqiyatli yangilandi"

msgid "Oil change history added successfully."
msgstr "Yog' almashtirish tarixi muvaffaqiyatli qo'shildi."

msgid "Oil change history retrieved successfully."
msgstr "Yog' almashtirish tarixi muvaffaqiyatli olindi."

msgid "Oil change history updated successfully."
msgstr "Yog' almashtirish tarixi muvaffaqiyatli yangilandi."

msgid "Oil change history partially updated successfully."
msgstr "Yog' almashtirish tarixi qisman muvaffaqiyatli yangilandi."

msgid "Oil change history deleted successfully."
msgstr "Yog' almashtirish tarixi muvaffaqiyatli o'chirildi."

msgid "You can only add oil change history for your own cars."
msgstr "Siz faqat o'zingizning mashinalaringiz uchun yog' almashtirish tarixini qo'sha olasiz."

msgid "Category depth must be <= 2"
msgstr "Kategoriya chuqurligi <= 2 bo'lishi kerak"

msgid "Cannot add subcategory to a category that has products."
msgstr "Mahsulotlari bo'lgan kategoriyaga quyi kategoriya qo'shib bo'lmaydi."

msgid "Product can only be assigned to a leaf category (one that has no subcategories)."
msgstr "Mahsulot faqat barg kategoriyasiga (quyi kategoriyalari bo'lmagan) tayinlanishi mumkin."

msgid "Category depth must be 2 levels or less"
msgstr "Kategoriya chuqurligi 2 daraja yoki undan kam bo'lishi kerak"

msgid "Cannot add a subcategory to a category that already has products."
msgstr "Mahsulotlari bo'lgan kategoriyaga quyi kategoriya qo'shib bo'lmaydi."

msgid "Price must be greater than or equal to 0."
msgstr "Narx 0 dan katta yoki teng bo'lishi kerak."

msgid "You have recently used an SMS code, please wait {seconds} seconds for a new one"
msgstr "Yaqinda SMS koddan foydalangansiz, yangisi uchun {seconds} soniya kuting"

msgid "This car number is already taken. Please use a unique number."
msgstr "Bu mashina raqami allaqachon band qilingan. Iltimos, noyob raqamdan foydalaning."

msgid "User account deleted successfully."
msgstr "Foydalanuvchi hisobi muvaffaqiyatli o'chirildi."

msgid "Your verification code to access the Carland system is: {code}. Please do not share this code with anyone."
msgstr "Carland tizimiga kirish uchun tasdiqlash kodi: {code}. Iltimos, ushbu kodni hech kimga bermang."

msgid "Code for deleting accounting data in the Carland.uz system: {code}"
msgstr "Carland.uz tizimidagi hisob ma'lumotlarini o'chirish uchun kod: {code}"

msgid "OTP verified successfully"
msgstr "OTP muvaffaqiyatli tasdiqlandi"

