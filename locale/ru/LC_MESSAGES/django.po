msgid "This promo code has expired"
msgstr "Срок действия промокода истёк"

msgid "This promo code has no remaining uses"
msgstr "Этот промокод больше не используется"

msgid "No appointment found for this branch"
msgstr "Запись не найдена для данного филиала"

msgid "Notification marked as read"
msgstr "Уведомление отмечено как прочитанное"

msgid "All notifications marked as read"
msgstr "Все уведомления отмечены как прочитанные"

