msgid "OTP sent successfully"
msgstr "OTP успешно отправлен"

msgid "You have a recent SMS that you can use"
msgstr "У вас есть недавнее SMS, которое можно использовать"

msgid "OTP code has expired"
msgstr "Срок действия кода OTP истёк"

msgid "You already have an active OTP that you can use. Please wait %(seconds)s seconds before requesting a new one."
msgstr "У вас уже есть активный код OTP. Пожалуйста, подождите %(seconds)s секунд перед запросом нового."

msgid "You have exceeded the SMS limit for the last 24 hours. Please wait {hours} hours before sending another SMS"
msgstr "Вы превысили лимит SMS за последние 24 часа. Пожалуйста, подождите {hours} часов, прежде чем отправить другое SMS"

msgid "Provided phone number doesn't match your current phone number"
msgstr "Указанный номер телефона не соответствует вашему текущему номеру"

msgid "Current phone number verified successfully"
msgstr "Текущий номер телефона успешно подтверждён"

msgid "This phone number is already registered by another user"
msgstr "Этот номер телефона уже зарегистрирован другим пользователем"

msgid "Phone number changed successfully"
msgstr "Номер телефона успешно изменён"

msgid "Invalid OTP code or phone number"
msgstr "Неверный код OTP или номер телефона"

msgid "OTP not found for this phone number."
msgstr "Для этого номера телефона не найден код OTP."

msgid "OTP code has already been used."
msgstr "Код OTP уже был использован."

msgid "OTP has expired."
msgstr "Срок действия OTP истёк."

msgid "Invalid OTP code."
msgstr "Неверный код OTP."

msgid "The phone field must be set"
msgstr "Поле телефона должно быть заполнено"

msgid "Superuser must have is_staff=True"
msgstr "Суперпользователь должен иметь is_staff=True"

msgid "Superuser must have is_superuser=True"
msgstr "Суперпользователь должен иметь is_superuser=True"

msgid "You cannot mark the primary address as 'non-primary'. To perform this action, please set another address as the primary one first."
msgstr "Нельзя снять статус 'основной' с этого адреса. Пожалуйста, сначала назначьте другой адрес как основной."

msgid "Rating can only be given for completed bookings."
msgstr "Оценка может быть оставлена только за завершённые бронирования."

msgid "You have already rated this booking."
msgstr "Вы уже оценили это бронирование."

msgid "Booking is required."
msgstr "Бронирование обязательно."

msgid "At least one field must be filled (image, video, or caption)."
msgstr "Должно быть заполнено хотя бы одно поле (изображение, видео или подпись)."

msgid "All image fields must be provided if any are filled."
msgstr "Если заполнено одно поле изображения, необходимо заполнить все поля изображений."

msgid "All video fields must be provided if any are filled."
msgstr "Если заполнено одно поле видео, необходимо заполнить все поля видео."

msgid "All caption fields must be provided if any are filled."
msgstr "Если заполнено одно поле подписи, необходимо заполнить все поля подписей."

msgid "Cars retrieved successfully"
msgstr "Список автомобилей успешно получен"

msgid "Car retrieved successfully"
msgstr "Автомобиль успешно получен"

msgid "Car created successfully"
msgstr "Автомобиль успешно создан"

msgid "Car updated successfully"
msgstr "Автомобиль успешно обновлён"

msgid "Car partially updated successfully"
msgstr "Автомобиль частично обновлён"

msgid "Oil change history added successfully."
msgstr "История замены масла успешно добавлена."

msgid "Oil change history retrieved successfully."
msgstr "История замены масла успешно получена."

msgid "Oil change history updated successfully."
msgstr "История замены масла успешно обновлена."

msgid "Oil change history partially updated successfully."
msgstr "История замены масла частично обновлена."

msgid "Oil change history deleted successfully."
msgstr "История замены масла успешно удалена."

msgid "You can only add oil change history for your own cars."
msgstr "Вы можете добавлять историю замены масла только для своих автомобилей."

msgid "Category depth must be <= 2"
msgstr "Глубина категории должна быть меньше или равна 2"

msgid "Cannot add subcategory to a category that has products."
msgstr "Невозможно добавить подкатегорию в категорию, которая уже имеет продукты."

msgid "Product can only be assigned to a leaf category (one that has no subcategories)."
msgstr "Продукт может быть назначен только в конечную категорию (категорию без подкатегорий)."

msgid "Category depth must be 2 levels or less"
msgstr "Глубина категории должна быть не более 2 уровней"

msgid "Price must be greater than or equal to 0."
msgstr "Цена должна быть больше или равна 0."

msgid "You have recently used an SMS code, please wait {seconds} seconds for a new one"
msgstr "Вы недавно использовали SMS-код, пожалуйста, подождите {seconds} секунд для нового"

msgid "This car number is already taken. Please use a unique number."
msgstr "Этот номер автомобиля уже занят. Пожалуйста, используйте уникальный номер."

msgid "User account deleted successfully."
msgstr "Аккаунт пользователя успешно удалён."

msgid "Your verification code to access the Carland system is: {code}. Please do not share this code with anyone."
msgstr "Код подтверждения для входа в систему Carland: {code}. Пожалуйста, никому не сообщайте этот код."

msgid "Code for deleting accounting data in the Carland.uz system: {code}"
msgstr "Код для удаления учетных данных в системе Carland.uz: {code}"

msgid "OTP verified successfully"
msgstr "OTP успешно подтвержден"

