msgstr "История отмечена как прочитанная"

msgid "You are not authorized to mark this story as viewed"
msgstr "Вы не имеете прав для отметки истории как прочитанной"

msgid "Car number is not valid in Uzbekistan"
msgstr "Номер автомобиля недействителен в Узбекистане."

msgid "Order amount exceeds the maximum limit of %(max_amount)s"
msgstr "Сумма заказа превышает максимально допустимый лимит %(max_amount)s"

