msgstr "При выборе способа оплаты «Карта» требуется идентификатор карты."

msgid "Pickup time is required for pickup orders"
msgstr "Для заказов с самовывозом требуется время получения"

msgid "Pickup time must be at least tomorrow"
msgstr "Время получения должно быть не позднее завтрашнего дня."

msgid "Invalid or expired promo code"
msgstr "Недействительный или просроченный промокод"

msgid "You can only rate completed orders"
msgstr "Вы можете оценивать только выполненные заказы."

msgid "You can only rate your own orders"
msgstr "Вы можете оценивать только свои собственные заказы."

msgid "You have already rated this order"
msgstr "Вы уже оценили этот заказ"

msgid "Basket has been cleared."
msgstr "Корзина очищена."

