msgstr "Кэшбэк можно использовать только с кэшбэком, смешанным или онлайн-способами оплаты"

msgid "Secondary payment method is required for MIXED payments"
msgstr "Для смешанных платежей требуется вторичный способ оплаты"

msgid "Cashback balance amount is not more than {min_amount}."
msgstr "Сумма баланса кэшбека не превышает {min_amount}."

msgid "Insufficient cashback balance to cover order amount"
msgstr "Недостаточно кэшбэк-баланса для покрытия суммы заказа"

msgid "Amount is less than 500 UZS after cashback deduction"
msgstr "Сумма менее 500 UZS после вычета кэшбэка"

msgid "Order amount is more than {max_amount} to use cashback."
msgstr "Сумма заказа для использования кэшбэка превышает {max_amount}."

