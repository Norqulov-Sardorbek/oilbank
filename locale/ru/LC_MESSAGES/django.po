msgstr "Бронирование успешно создано."

msgid "Booking updated successfully."
msgstr "Бронирование успешно обновлено."

msgid "Branch is required for pickup orders"
msgstr "Для заказов с самовывозом требуется наличие отделения"

msgid "Address is required for delivery orders"
msgstr "Для заказов с доставкой требуется адрес"

